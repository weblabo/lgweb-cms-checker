{
   "manifest_version": 3,
   "name": "自治体サイト CMS Checker",
   "version": "0.2",
   "description": "自治体サイトで使われているCMSをチェックするアドオン",
   "permissions": [
      "activeTab",
      "scripting"
    ],
    "action": {
      "default_popup": "cms_checker_popup.html"
    },
   "icons": {
     "16": "icons/icon16.png",
     "48": "icons/icon48.png",
     "128": "icons/icon128.png"
   },
   "web_accessible_resources": [
    {
      "resources": [
        "lgweb.csv"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
 }