{
  "manifest_version": 3,
  "name": "自治体サイト CMS Checker",
  "version": "1.0",
  "description": "自治体サイトで使われているCMSをチェックするアドオン",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "cms_checker_popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "data/lgweb.csv"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}